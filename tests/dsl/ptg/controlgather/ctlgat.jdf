#define MY_RANK(dc, r) int r = (int)((dc)->myrank)
%}

%option no_taskpool_instance = true  /* can be anything */

A          [type = "parsec_data_collection_t*"]
NT
WS

TA(k)

k = 0 .. NT-1
: A( k % WS )

CTL X -> X TC(0)

; 0

BODY
    MY_RANK(A, r);
    printf("%d: TA(%d)\n", r, k);
END

TB(k)

k = 0 .. NT-1
: A( k % WS )

CTL X -> Y TC(0)

; 0

BODY
    MY_RANK(A, r);
    printf("%d: TB(%d)\n", r, k);
END

TC(k)

k = 0..0
: A( 0 )

CTL X <- X TA(0..NT-1)
CTL Y <- X TB(0..NT-1)

; 0

BODY
    MY_RANK(A, r);
    printf("%d: TC(%d)\n", r, k);
END
extern "C" %{
%}
