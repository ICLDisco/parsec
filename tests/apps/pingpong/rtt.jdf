/*
 * RTT test shared by tests/apps/pingpong and tests/runtime/cuda.
 *
 * The apps/pingpong test runs one CPU-only fragment chain to expose
 * latency/round-trip behavior. The runtime/cuda test can run multiple
 * fragment chains and restricts the same PTG to CUDA devices to exercise GPU
 * communication.
 */
int rtt_verbose = 0;
%}

%option no_taskpool_instance = true  /* can be anything */

NT
FRAGS
WS

PING(k, f)

k = 0 .. NT-1
f = 0 .. FRAGS-1
: A(f, k % WS)

RW T <- (k == 0) ? A(f, k % WS) : T PING(k-1, f)
     -> (k < NT-1) ? T PING(k+1, f)
     -> (k == NT-1) ? A(f, k % WS)

; 0

BODY [type = CUDA]
	if( rtt_verbose ) {
		printf("ping(%d, %d)\n", k, f);
	}
END

BODY
	if( rtt_verbose ) {
		printf("ping(%d, %d)\n", k, f);
	}
END
